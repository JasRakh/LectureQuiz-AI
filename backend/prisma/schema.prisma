generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  lectures     Lecture[]     @relation("ProfessorLectures")
  quizResults  QuizResult[]
  courses      Course[]      @relation("ProfessorCourses")
  enrollments  Enrollment[]  @relation("StudentEnrollments")
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())

  professor   User     @relation("ProfessorCourses", fields: [professorId], references: [id])
  professorId Int

  lectures    Lecture[]
  enrollments Enrollment[]
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  student   User   @relation("StudentEnrollments", fields: [studentId], references: [id])
  studentId Int
  course    Course @relation(fields: [courseId], references: [id])
  courseId   Int

  @@unique([studentId, courseId])
}

model Lecture {
  id            Int      @id @default(autoincrement())
  title         String
  videoUrl      String
  transcript    String?  @db.Text
  bulletPoints  String?  @db.Text
  createdAt     DateTime @default(now())

  professor   User     @relation("ProfessorLectures", fields: [professorId], references: [id])
  professorId Int

  course   Course? @relation(fields: [courseId], references: [id])
  courseId  Int?

  quizzes     Quiz[]
}

model Quiz {
  id              Int      @id @default(autoincrement())
  lecture         Lecture  @relation(fields: [lectureId], references: [id])
  lectureId       Int
  generatedFromAI Boolean  @default(true)
  createdAt       DateTime @default(now())

  questions   Question[]
  results     QuizResult[]
}

model Question {
  id            Int      @id @default(autoincrement())
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  quizId        Int
  question      String
  options       String // JSON stringified array of options
  correctAnswer String
}

model QuizResult {
  id        Int      @id @default(autoincrement())
  student   User     @relation(fields: [studentId], references: [id])
  studentId Int
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  quizId    Int
  score     Int
  createdAt DateTime @default(now())
}

enum Role {
  student
  professor
}
