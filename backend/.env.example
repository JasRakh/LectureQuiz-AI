# Server
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/final
JWT_SECRET=super-secret-key
FRONTEND_ORIGIN=http://localhost:3000

# Public URL used in stored lecture videoUrl after upload (no trailing slash)
API_PUBLIC_URL=http://localhost:4000

# Uploaded videos (relative to backend cwd or absolute path)
UPLOAD_DIR=uploads

# FFmpeg: full path to ffmpeg.exe on Windows if not on PATH
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

# OpenAI (Whisper API when WHISPER_BACKEND=openai)
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini

# Whisper: openai | local
WHISPER_BACKEND=openai
# Optional ISO-639-1 language code, e.g. en
# WHISPER_LANGUAGE=en

# Local Whisper (WHISPER_BACKEND=local): python on PATH or full path to python.exe
WHISPER_LOCAL_PYTHON=python3
WHISPER_LOCAL_MODEL=tiny
WHISPER_LOCAL_FP16=false
# WHISPER_LOCAL_DEVICE=cpu
# Extra args before -m whisper, space-separated
# WHISPER_LOCAL_PY_ARGS=

